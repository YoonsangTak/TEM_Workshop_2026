&CONTROL
  calculation = 'scf'
  prefix      = 'si'
  outdir      = '../tmp/'
  pseudo_dir  = '../pseudo/'
  tprnfor = .true.,  tstress = .true.
/
&SYSTEM
  ibrav = 2,  celldm(1) = 10.338
  nat = 2,    ntyp = 1
  ecutwfc = 40
/
&ELECTRONS
  conv_thr = 1.0d-6
/
ATOMIC_SPECIES
  Si 28.0855 Si.pbe-n-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS alat
  Si  0.00  0.00  0.00
  Si  0.25  0.25  0.25
K_POINTS automatic
  12 12 12  1 1 1

