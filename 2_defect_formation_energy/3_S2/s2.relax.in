&CONTROL
  calculation = 'relax'
  prefix      = 'S2_mol'
  outdir      = './tmp/'
  pseudo_dir  = '../pseudo/'
  tprnfor     = .true.
/
&SYSTEM
  ibrav   = 1
  A       = 12.0
  nat     = 2
  ntyp    = 1
  ecutwfc = 40.0
  ecutrho = 320.0
  nspin             = 2
  tot_magnetization = 2
  occupations = 'smearing'
  smearing    = 'gaussian'
  degauss     = 0.01
/
&ELECTRONS
  conv_thr    = 1.0d-6
  mixing_beta = 0.3
/
&IONS
  ion_dynamics = 'bfgs'
/
ATOMIC_SPECIES
  S  32.065  S.pbe-n-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS angstrom
  S  7.50  7.50  6.55
  S  7.50  7.50  8.45
K_POINTS gamma

