&CONTROL
  calculation   = 'vc-relax'
  prefix        = 'Si'
  outdir        = './tmp/'
  pseudo_dir    = '../pseudo/'
  forc_conv_thr = 1.0d-3
  etot_conv_thr = 1.0d-4
/
&SYSTEM
  ibrav = 0
  nat = 8
  ntyp = 1
  ecutwfc = 40.0
  ecutrho = 320.0
/
&ELECTRONS  
conv_thr = 1.0d-6  
/
&IONS
ion_dynamics = 'bfgs'
/
&CELL  
cell_dynamics='bfgs'
cell_dofree = 'ibrav'
/
ATOMIC_SPECIES
  Si 28.0855  Si.pbe-n-rrkjus_psl.1.0.0.UPF
CELL_PARAMETERS angstrom 
  5.43  0.00  0.00
  0.00  5.43  0.00
  0.00  0.00  5.43
ATOMIC_POSITIONS crystal
  Si 0.00 0.00 0.00
  Si 0.50 0.50 0.00
  Si 0.50 0.00 0.50
  Si 0.00 0.50 0.50
  Si 0.25 0.25 0.25
  Si 0.75 0.75 0.25
  Si 0.75 0.25 0.75
  Si 0.25 0.75 0.75
K_POINTS automatic
  6 6 6  1 1 1
